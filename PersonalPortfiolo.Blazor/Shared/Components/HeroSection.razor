@inject ISettingsService SettingsService

<section class="hero">
    <div class="hero-content">
        <h1 class="hero-title animate-fade-in-up stagger-1">
            Hi, I'm <span class="text-gradient">Nicholas Martin</span>
        </h1>
        
        <p class="hero-subtitle animate-fade-in-up stagger-2">
            Senior .NET Full Stack Software Engineer
        </p>
        
        <p class="hero-description animate-fade-in-up stagger-3">
            Building enterprise solutions and exploring new technologies. 
            Passionate about clean code, scalable architecture, and continuous learning.
        </p>
        
        <div class="hero-cta animate-fade-in-up stagger-4">
            <a href="about" class="btn btn-primary">
                Learn More
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </a>
            <a href="@SettingsService.GetSettings().GitHubProfileUri" target="_blank" class="btn btn-outline">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub
            </a>
        </div>
        
        <div class="hero-tech animate-fade-in-up stagger-5">
            <span class="tech-label">Tech I work with</span>
            <div class="tech-tags">
                <span class="badge">C#/.NET</span>
                <span class="badge">MAUI</span>
                <span class="badge">Xamarin</span>
                <span class="badge">Blazor</span>
                <span class="badge">Azure</span>
                <span class="badge">Docker</span>
                <span class="badge">Agentic AI</span>
            </div>
        </div>
    </div>
    
    <div class="hero-visual animate-fade-in">
        <div class="code-block">
            <div class="code-header">
                <span class="dot red"></span>
                <span class="dot yellow"></span>
                <span class="dot green"></span>
            </div>
            <pre class="code-content"><code><span class="keyword">public</span> <span class="keyword">class</span> <span class="type">Developer</span>
{
    <span class="keyword">private</span> <span class="type">BioBuilder</span> _builder = new();
    
    <span class="keyword">public</span> <span class="keyword">async</span> <span class="keyword">Task&lt;Bio&gt;</span> InitializeAsync()
    {
        return <span class="keyword">await</span> <span class="keyword">_builder</span>
            .WithName(<span class="type">"Nicholas Martin"</span>)
            .WithTitle(<span class="type">".NET Developer"</span>)
            .AddWebSkills(
                <span class="type">WebTech</span>.AspNetCore,
                <span class="type">WebTech</span>.Blazor,
                <span class="type">WebTech</span>.Azure)
            .AddMobileSkills(
                <span class="type">MobileTech</span>.MAUI,
                <span class="type">MobileTech</span>.Xamarin)
            .AddBackendSkills(
                <span class="type">BackendTech</span>.Sql,
                <span class="type">BackendTech</span>.WorkerServices,
                <span class="type">BackendTech</span>.EntityFramework)
            .BuildAsync();
    }
}</code></pre>
        </div>
    </div>
</section>

<style>
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 8rem 1.5rem 4rem;
        max-width: 1200px;
        margin: 0 auto;
        gap: 4rem;
    }

    .hero-content {
        flex: 1;
        max-width: 640px;
    }

    .hero-badge {
        margin-bottom: 1.5rem;
    }

    .hero-title {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        margin-bottom: 0.75rem;
        line-height: 1.1;
    }

    .hero-subtitle {
        font-size: 1.5rem;
        color: var(--accent-cyan);
        font-weight: 500;
        margin-bottom: 1.25rem;
    }

    .hero-description {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin-bottom: 2rem;
        max-width: 520px;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
    }

    .hero-tech {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .tech-label {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .tech-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .hero-visual {
        flex: 1;
        display: none;
    }

    @@media (min-width: 1024px) {
        .hero-visual {
            display: block;
        }
    }

    .code-block {
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .code-header {
        display: flex;
        gap: 6px;
        padding: 12px 16px;
        background: var(--bg-elevated);
        border-bottom: 1px solid var(--border-subtle);
    }

    .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .dot.red { background: #FF5F56; }
    .dot.yellow { background: #FFBD2E; }
    .dot.green { background: #27CA40; }

    .code-content {
        padding: 1.5rem;
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        line-height: 1.7;
        overflow-x: auto;
    }

    .code-content code {
        color: var(--text-secondary);
    }

    .keyword { color: #C792EA; }
    .type { color: #82AAFF; }
    .string { color: #C3E88D; }
</style>
