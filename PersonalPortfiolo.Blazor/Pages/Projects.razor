@page "/projects"

<section class="section">
    <div class="container">
        <div class="section-header animate-fade-in-up">
            <h1 class="section-title">Projects</h1>
            <p class="section-subtitle">
                Explore my GitHub repositories. I love building applications that test my abilities 
                and explore new technologies.
            </p>
        </div>

        <GitHubProfile 
            ProfileUri="@ViewModel.GitHubProfileUri" 
            ProfileApiUri="@ViewModel.GitHubProfileApiUri" 
        />
    </div>
</section>

@code {
    [Inject] public ProjectsViewModel ViewModel { get; set; } = null!;
}
