@page "/contact"

<section class="section">
    <div class="container">
        <div class="section-header animate-fade-in-up" style="text-align: center;">
            <h1 class="section-title">Get In Touch</h1>
            <p class="section-subtitle">
                Feel free to reach out to me on any of these platforms.
            </p>
        </div>

        <div class="contact-grid">
            @foreach (var link in ViewModel.ContactLinks)
            {
                <a href="@link.Uri" target="_blank" class="contact-card animate-fade-in-up">
                    <div class="contact-icon">
                        @if (link.Title?.Equals("GitHub", StringComparison.OrdinalIgnoreCase) == true)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                            </svg>
                        }
                        else if (link.Title?.Equals("LinkedIn", StringComparison.OrdinalIgnoreCase) == true)
                        {
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                            </svg>
                        }
                    </div>
                    <h3 class="contact-title">@link.Title</h3>
                    <p class="contact-desc">Connect with me on @link.Title</p>
                    <span class="contact-arrow">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
                        </svg>
                    </span>
                </a>
            }
            
            <a href="@ViewModel.ResumeLink" target="_blank" class="contact-card animate-fade-in-up">
                <div class="contact-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                </div>
                <h3 class="contact-title">Resume</h3>
                <p class="contact-desc">View my professional resume</p>
                <span class="contact-arrow">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
                    </svg>
                </span>
            </a>
        </div>
    </div>
</section>

<style>
    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        max-width: 800px;
        margin: 0 auto;
    }

    .contact-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 2.5rem 1.5rem;
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition: all var(--transition-normal);
        position: relative;
        overflow: hidden;
    }

    .contact-card:hover {
        border-color: var(--accent-cyan);
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }

    .contact-card:hover .contact-icon {
        background: var(--accent-cyan);
        color: var(--bg-primary);
    }

    .contact-card:hover .contact-arrow {
        opacity: 1;
        transform: translateX(0);
    }

    .contact-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 72px;
        height: 72px;
        background: var(--bg-elevated);
        border-radius: 50%;
        color: var(--text-secondary);
        margin-bottom: 1.25rem;
        transition: all var(--transition-normal);
    }

    .contact-title {
        font-size: 1.25rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .contact-desc {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin: 0;
    }

    .contact-arrow {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        color: var(--accent-cyan);
        opacity: 0;
        transform: translateX(-10px);
        transition: all var(--transition-normal);
    }
</style>

@code {
    [Inject] public ContactViewModel ViewModel { get; set; } = null!;
}
